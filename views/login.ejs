<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login | FullStack Cafe</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root { --coffee: #5d4037; --accent: #e67e22; }
        .focus-ring:focus { border-color: var(--accent); box-shadow: 0 0 0 4px rgba(230, 126, 34, 0.1); }
        
        /* Shake Animation for errors */
        @keyframes shake {
            0%, 100% { transform: translateX(0); }
            25% { transform: translateX(-8px); }
            75% { transform: translateX(8px); }
        }
        .shake { animation: shake 0.4s ease-in-out; }
    </style>
</head>
<body class="bg-[#fcf8f5] font-sans antialiased text-gray-900 overflow-x-hidden">

    <div id="errorPopup" class="fixed bottom-8 left-1/2 -translate-x-1/2 z-[100] hidden flex items-center gap-4 bg-white border-l-4 border-red-500 px-6 py-4 rounded-2xl shadow-2xl transition-all duration-500 transform translate-y-32">
        <div class="bg-red-50 p-2 rounded-full text-red-500">
            <i class="fas fa-exclamation-triangle text-lg"></i>
        </div>
        <div>
            <p class="text-[10px] font-black uppercase tracking-widest text-gray-400 leading-none mb-1">Login Error</p>
            <p id="errorPopupMsg" class="text-sm font-bold text-slate-800">Invalid credentials</p>
        </div>
        <button onclick="hidePopup()" class="ml-4 text-gray-300 hover:text-gray-500">
            <i class="fas fa-times"></i>
        </button>
    </div>

    <%- include('partials/navbar', { user: locals.user || null }) %>

    <main class="min-h-[calc(100vh-80px)] flex items-center justify-center px-4 py-12">
        
        <div id="loginCard" class="w-full max-w-md bg-white rounded-3xl p-8 md:p-10 shadow-xl shadow-brown-100/10 border border-gray-100 transition-transform">
            
            <div class="text-center mb-10">
                <div class="inline-flex items-center justify-center w-16 h-16 bg-orange-50 rounded-full mb-4">
                    <i class="fas fa-mug-hot text-[#e67e22] text-2xl"></i>
                </div>
                <h2 class="text-3xl font-black text-[#5d4037]">Welcome Back</h2>
                <p class="text-gray-500 text-sm mt-2">Log in to track your treats and orders.</p>
            </div>

            <form id="loginForm" class="space-y-6">
                
                <div class="space-y-1">
                    <label for="email" class="text-[11px] font-black uppercase tracking-widest text-gray-400 ml-1">Email Address</label>
                    <div class="relative group">
                        <span class="absolute inset-y-0 left-0 pl-4 flex items-center text-gray-400 group-focus-within:text-[#e67e22] transition-colors">
                            <i class="fas fa-envelope"></i>
                        </span>
                        <input type="email" id="email" placeholder="coffee@lover.com" required
                            class="w-full pl-11 pr-4 py-3.5 bg-gray-50 border border-gray-100 rounded-2xl outline-none focus:border-[#e67e22] focus:ring-4 focus:ring-orange-50 transition-all">
                    </div>
                </div>

                <div class="space-y-1">
                    <div class="flex justify-between items-center px-1">
                        <label for="password" class="text-[11px] font-black uppercase tracking-widest text-gray-400">Password</label>
                        <a href="/forgot-password" class="text-[11px] font-bold text-[#e67e22] hover:underline uppercase tracking-widest flex items-center gap-1">
                            <i class="fas fa-key text-[10px]"></i> Forgot?
                        </a>
                    </div>
                    <div class="relative group">
                        <span class="absolute inset-y-0 left-0 pl-4 flex items-center text-gray-400 group-focus-within:text-[#e67e22] transition-colors">
                            <i class="fas fa-lock"></i>
                        </span>
                        
                        <input type="password" id="password" placeholder="••••••••" required
                            class="w-full pl-11 pr-12 py-3.5 bg-gray-50 border border-gray-100 rounded-2xl outline-none focus:border-[#e67e22] focus:ring-4 focus:ring-orange-50 transition-all">
                        
                        <button type="button" id="togglePassword" class="absolute inset-y-0 right-0 pr-4 flex items-center text-gray-400 hover:text-[#5d4037] transition-colors">
                            <i class="fas fa-eye" id="eyeIcon"></i>
                        </button>
                    </div>
                </div>

                <button type="submit" id="submitBtn"
                    class="w-full bg-[#5d4037] text-white py-4 rounded-2xl font-bold text-lg shadow-lg shadow-brown-200 hover:bg-[#4a332c] active:scale-[0.98] transition-all flex items-center justify-center gap-3">
                    Login to Account
                    <i class="fas fa-arrow-right text-sm"></i>
                </button>
            </form>

            <div class="mt-8 text-center">
                <p class="text-gray-500 text-sm">
                    Don't have an account? 
                    <a href="/signup" class="text-[#e67e22] font-black hover:underline ml-1">Signup here</a>
                </p>
            </div>
        </div>
    </main>

    <script>
        // --- 1. Password Visibility Toggle ---
        const togglePassword = document.querySelector('#togglePassword');
        const passwordInput = document.querySelector('#password');
        const eyeIcon = document.querySelector('#eyeIcon');

        togglePassword.addEventListener('click', function() {
            const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password';
            passwordInput.setAttribute('type', type);
            eyeIcon.classList.toggle('fa-eye');
            eyeIcon.classList.toggle('fa-eye-slash');
        });

        // --- 2. Popup Control Logic (Bottom Placement) ---
        let popupTimeout;

        function showPopup(message) {
            const popup = document.getElementById('errorPopup');
            const msgContainer = document.getElementById('errorPopupMsg');
            const card = document.getElementById('loginCard');

            msgContainer.textContent = message;
            
            // Remove hidden and slide UP from bottom
            popup.classList.remove('hidden');
            setTimeout(() => {
                popup.classList.remove('translate-y-32');
                popup.classList.add('translate-y-0');
            }, 10);

            // Add shake effect to login card
            card.classList.add('shake');
            setTimeout(() => card.classList.remove('shake'), 400);

            // Auto-hide after 5 seconds
            if (popupTimeout) clearTimeout(popupTimeout);
            popupTimeout = setTimeout(hidePopup, 5000);
        }

        function hidePopup() {
            const popup = document.getElementById('errorPopup');
            popup.classList.add('translate-y-32');
            popup.classList.remove('translate-y-0');
            setTimeout(() => {
                popup.classList.add('hidden');
            }, 500);
        }

        // --- 3. Helper: Convert VAPID Key ---
        function urlBase64ToUint8Array(base64String) {
            const padding = "=".repeat((4 - (base64String.length % 4)) % 4);
            const base64 = (base64String + padding).replace(/-/g, "+").replace(/_/g, "/");
            const rawData = window.atob(base64);
            const outputArray = new Uint8Array(rawData.length);
            for (let i = 0; i < rawData.length; ++i) {
                outputArray[i] = rawData.charCodeAt(i);
            }
            return outputArray;
        }

        // --- 4. Login Form Handling ---
        const loginForm = document.getElementById('loginForm');
        const submitBtn = document.getElementById('submitBtn');

        loginForm.addEventListener('submit', async (e) => {
            e.preventDefault();

            const email = document.getElementById('email').value;
            const password = document.getElementById('password').value;

            submitBtn.disabled = true;
            submitBtn.innerHTML = `<i class="fas fa-circle-notch fa-spin"></i> Checking...`;

            let subscription = null;

            // Attempt to get Push Subscription
            try {
                if ('serviceWorker' in navigator && 'PushManager' in window) {
                    const registration = await navigator.serviceWorker.register('/sw.js');
                    const permission = await Notification.requestPermission();
                    if (permission === 'granted') {
                        const publicVapidKey = "<%= process.env.PUBLIC_VAPID_KEY %>";
                        subscription = await registration.pushManager.subscribe({
                            userVisibleOnly: true,
                            applicationServerKey: urlBase64ToUint8Array(publicVapidKey)
                        });
                    }
                }
            } catch (pushErr) {
                console.warn("Push subscription failed:", pushErr);
            }

            const urlParams = new URLSearchParams(window.location.search);
            const returnTo = urlParams.get('returnTo') || '';

            try {
                const res = await fetch(`/login?returnTo=${encodeURIComponent(returnTo)}`, {
                    method: 'POST',
                    body: JSON.stringify({ email, password, subscription }), 
                    headers: { 'Content-Type': 'application/json' }
                });

                const data = await res.json();

                if (data.success) {
                    window.location.assign(data.redirectUrl || '/'); 
                } else {
                    showPopup(data.error || "Login failed. Check your email/password.");
                    resetBtn();
                }
            } catch (err) {
                console.error("Login Error:", err);
                showPopup("Connection error. Please try again.");
                resetBtn();
            }
        });

        function resetBtn() {
            submitBtn.disabled = false;
            submitBtn.innerHTML = `Login to Account <i class="fas fa-arrow-right text-sm"></i>`;
        }
    </script>
</body>
</html>