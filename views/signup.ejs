<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Signup | FullStack Cafe</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        .toast {
            visibility: hidden;
            min-width: 300px;
            color: #fff;
            text-align: center;
            border-radius: 16px;
            padding: 16px 24px;
            position: fixed;
            z-index: 1000;
            left: 50%;
            bottom: 30px;
            transform: translateX(-50%);
            opacity: 0;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            box-shadow: 0 10px 25px rgba(0,0,0,0.15);
            font-weight: 600;
        }
        .toast.show { visibility: visible; opacity: 1; bottom: 50px; }
    </style>
</head>
<body class="bg-[#fcf8f5] font-sans antialiased text-gray-900">

<%- include('partials/navbar', { user: user }) %>

<main class="min-h-[calc(100vh-80px)] flex items-center justify-center px-4 py-12">
    
    <div class="w-full max-w-md bg-white rounded-3xl p-8 md:p-10 shadow-xl shadow-brown-100/10 border border-gray-100">
        
        <div class="text-center mb-8">
            <h2 class="text-3xl font-black text-[#5d4037] tracking-tight">Create Account</h2>
            <p class="text-gray-500 text-sm mt-2 font-medium">Join the FullStack Cafe community</p>
        </div>

        <form id="signupForm" class="space-y-5">
            <div class="space-y-1">
                <label class="text-[11px] font-black uppercase tracking-widest text-gray-400 ml-1">Username</label>
                <div class="relative">
                    <i class="fas fa-user absolute left-4 top-1/2 -translate-y-1/2 text-gray-300 text-sm"></i>
                    <input type="text" id="username" placeholder="Enter username" required
                        class="w-full pl-11 pr-4 py-3.5 bg-gray-50 border border-gray-100 rounded-2xl outline-none focus:border-[#e67e22] focus:ring-4 focus:ring-orange-50 transition-all text-[#5d4037] font-semibold placeholder:text-gray-300">
                </div>
            </div>

            <div class="space-y-1">
                <label class="text-[11px] font-black uppercase tracking-widest text-gray-400 ml-1">Email Address</label>
                <div class="relative">
                    <i class="fas fa-envelope absolute left-4 top-1/2 -translate-y-1/2 text-gray-300 text-sm"></i>
                    <input type="email" id="email" placeholder="name@example.com" required
                        class="w-full pl-11 pr-4 py-3.5 bg-gray-50 border border-gray-100 rounded-2xl outline-none focus:border-[#e67e22] focus:ring-4 focus:ring-orange-50 transition-all text-[#5d4037] font-semibold placeholder:text-gray-300">
                </div>
            </div>

            <div class="space-y-1">
                <label class="text-[11px] font-black uppercase tracking-widest text-gray-400 ml-1">Password</label>
                <div class="relative">
                    <i class="fas fa-lock absolute left-4 top-1/2 -translate-y-1/2 text-gray-300 text-sm"></i>
                    <input type="password" id="password" placeholder="••••••••" required
                        class="w-full pl-11 pr-4 py-3.5 bg-gray-50 border border-gray-100 rounded-2xl outline-none focus:border-[#e67e22] focus:ring-4 focus:ring-orange-50 transition-all text-[#5d4037] font-semibold placeholder:text-gray-300">
                </div>
            </div>

            <button type="submit" id="signupBtn"
                class="w-full bg-[#5d4037] text-white py-4 rounded-2xl font-bold text-lg shadow-lg shadow-brown-200 hover:bg-[#4a332c] active:scale-[0.98] transition-all flex items-center justify-center gap-3 mt-4">
                Send Verification Code
            </button>
        </form>

        <div class="mt-8 text-center pt-6 border-t border-gray-50">
            <p class="text-sm text-gray-500 font-medium">
                Already have an account? 
                <a href="/login" class="text-[#e67e22] font-black hover:underline ml-1 uppercase tracking-tighter">Login here</a>
            </p>
        </div>
    </div>
</main>

<div id="toast" class="toast"></div>

<script>
    const toast = document.getElementById("toast");
    const signupForm = document.getElementById("signupForm");
    const signupBtn = document.getElementById("signupBtn");

    function showNotification(message, isError = true) {
        toast.innerText = message;
        toast.style.backgroundColor = isError ? "#d32f2f" : "#43a047";
        toast.classList.add("show");
        setTimeout(() => { toast.classList.remove("show"); }, 3500);
    }

    signupForm.addEventListener("submit", async (e) => {
        e.preventDefault();
        
        const username = document.getElementById("username").value;
        const email = document.getElementById("email").value;
        const password = document.getElementById("password").value;

        // Loading state
        signupBtn.innerHTML = `<i class="fas fa-circle-notch fa-spin text-xl"></i> Sending Code...`;
        signupBtn.disabled = true;

        try {
            const res = await fetch("/signup", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ username, email, password }) 
            });

            const data = await res.json();
            
            if (data.success) {
                sessionStorage.setItem("verifyEmail", email);
                showNotification("A 6-digit OTP has been sent to your email.", false);
                setTimeout(() => {
                    window.location.href = "/verify-otp";
                }, 2000);
            } else {
                showNotification(data.error || "Signup failed");
                signupBtn.innerText = "Send Verification Code";
                signupBtn.disabled = false;
            }
        } catch (err) {
            console.error(err);
            showNotification("An error occurred. Please try again.");
            signupBtn.innerText = "Send Verification Code";
            signupBtn.disabled = false;
        }
    });
</script>

</body>
</html>