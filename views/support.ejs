<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Support - FullStack Cafe</title>
</head>
<body>

<%- include('partials/navbar') %>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

<div class="support-wrapper" style="background: #fdf5e6; min-height: 90vh; padding: 40px 20px; font-family: 'Inter', 'Segoe UI', sans-serif;">
    <div class="container" style="max-width: 1100px; margin: 0 auto; display: flex; flex-wrap: wrap; gap: 40px; background: white; border-radius: 20px; overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.08);">
        
        <div style="flex: 1; min-width: 300px; background: #5d4037; color: white; padding: 60px 40px;">
            <h2 style="font-size: 2.5rem; margin-bottom: 20px;">Get in Touch</h2>
            <p style="color: #d7ccc8; line-height: 1.6; margin-bottom: 40px;">Have a complaint or a suggestion? We're here to help you 24/7. Fill out the form and our team will get back to you within 24 hours.</p>
            
            <div class="info-card" style="margin-bottom: 25px; display: flex; align-items: center; gap: 15px;">
                <div style="background: rgba(255,255,255,0.1); padding: 12px; border-radius: 12px;"><i class="fas fa-envelope"></i></div>
                <div>
                    <h4 style="margin: 0; font-size: 0.9rem; color: #bcaaa4;">Email Us</h4>
                    <p style="margin: 0;">support@fullstackcafe.com</p>
                </div>
            </div>

            <div class="info-card" style="margin-bottom: 25px; display: flex; align-items: center; gap: 15px;">
                <div style="background: rgba(255,255,255,0.1); padding: 12px; border-radius: 12px;"><i class="fas fa-phone"></i></div>
                <div>
                    <h4 style="margin: 0; font-size: 0.9rem; color: #bcaaa4;">Call Us</h4>
                    <p style="margin: 0;">+91 9876543210</p>
                </div>
            </div>

            <div style="margin-top: 60px; padding-top: 40px; border-top: 1px solid rgba(255,255,255,0.1);">
                <p style="font-size: 0.8rem; color: #bcaaa4;">Follow our social handles for updates.</p>
                <div style="display: flex; gap: 20px; font-size: 1.4rem; cursor: pointer;">
                    <i class="fab fa-instagram" style="transition: 0.3s;" onmouseover="this.style.color='#e67e22'" onmouseout="this.style.color='white'"></i>
                    <i class="fab fa-twitter" style="transition: 0.3s;" onmouseover="this.style.color='#e67e22'" onmouseout="this.style.color='white'"></i>
                    <i class="fab fa-facebook" style="transition: 0.3s;" onmouseover="this.style.color='#e67e22'" onmouseout="this.style.color='white'"></i>
                </div>
            </div>
        </div>

        <div style="flex: 1.5; min-width: 300px; padding: 60px 40px;">
            <div id="formContainer">
                <h3 style="color: #333; margin-top: 0;">Submit a Complaint</h3>
                <p style="color: #777; margin-bottom: 30px;">Fields marked with * are required.</p>

                <form id="supportForm">
                    <div style="display: flex; gap: 20px; margin-bottom: 20px; flex-wrap: wrap;">
                        <div style="flex: 1; min-width: 200px;">
                            <label style="display: block; font-size: 0.85rem; font-weight: 600; color: #555; margin-bottom: 8px;">Full Name *</label>
                            <input type="text" name="name" required style="width: 100%; padding: 12px; border: 1.5px solid #eee; border-radius: 8px; box-sizing: border-box; outline-color: #e67e22;">
                        </div>
                        <div style="flex: 1; min-width: 200px;">
                            <label style="display: block; font-size: 0.85rem; font-weight: 600; color: #555; margin-bottom: 8px;">Email Address *</label>
                            <input type="email" name="email" required style="width: 100%; padding: 12px; border: 1.5px solid #eee; border-radius: 8px; box-sizing: border-box; outline-color: #e67e22;">
                        </div>
                    </div>

                    <div style="margin-bottom: 20px;">
                        <label style="display: block; font-size: 0.85rem; font-weight: 600; color: #555; margin-bottom: 8px;">Product/Issue Topic *</label>
                        <input type="text" name="product" placeholder="e.g. Oreo Shake or Delivery Delay" required style="width: 100%; padding: 12px; border: 1.5px solid #eee; border-radius: 8px; box-sizing: border-box; outline-color: #e67e22;">
                    </div>

                    <div style="margin-bottom: 30px;">
                        <label style="display: block; font-size: 0.85rem; font-weight: 600; color: #555; margin-bottom: 8px;">Your Message *</label>
                        <textarea name="message" rows="5" placeholder="Please describe your issue in detail..." required style="width: 100%; padding: 12px; border: 1.5px solid #eee; border-radius: 8px; box-sizing: border-box; resize: vertical; outline-color: #e67e22;"></textarea>
                    </div>

                    <button type="submit" id="submitBtn" style="background: #e67e22; color: white; border: none; padding: 15px 30px; border-radius: 8px; font-weight: 600; cursor: pointer; transition: 0.3s; width: 100%; font-size: 1rem;">
                        Send Complaint
                    </button>
                </form>
            </div>

            <div id="successMessage" style="display: none; text-align: center; padding: 40px 0;">
                <div style="background: #e8f5e9; color: #2e7d32; width: 80px; height: 80px; line-height: 80px; border-radius: 50%; font-size: 2rem; margin: 0 auto 20px;">
                    <i class="fas fa-check"></i>
                </div>
                <h3 style="color: #333;">Complaint Received!</h3>
                <p style="color: #777; line-height: 1.6;">Thank you for contacting us.</p>
                <button onclick="window.location.reload()" style="background: transparent; border: 2px solid #e67e22; color: #e67e22; padding: 10px 25px; border-radius: 8px; margin-top: 20px; cursor: pointer; font-weight: bold; transition: 0.3s;" onmouseover="this.style.background='#e67e22'; this.style.color='white';" onmouseout="this.style.background='transparent'; this.style.color='#e67e22';">Send another message</button>
            </div>
        </div>
    </div>
</div>

<script>
    const supportForm = document.getElementById('supportForm');
    const submitBtn = document.getElementById('submitBtn');
    const formContainer = document.getElementById('formContainer');
    const successMessage = document.getElementById('successMessage');

    supportForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        // Show loading state
        submitBtn.disabled = true;
        submitBtn.style.opacity = '0.7';
        submitBtn.innerText = 'Submitting...';

        // Using FormData is correct, but we convert it to JSON for the backend
        const formData = new FormData(supportForm);
        const data = Object.fromEntries(formData.entries());

        try {
            const response = await fetch('/support', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });

            const result = await response.json();

            if (result.success) {
                // Smooth transition
                formContainer.style.opacity = '0';
                setTimeout(() => {
                    formContainer.style.display = 'none';
                    successMessage.style.display = 'block';
                    successMessage.style.opacity = '0';
                    setTimeout(() => successMessage.style.opacity = '1', 50);
                }, 300);
            } else {
                alert(result.message || 'Something went wrong. Please try again.');
                submitBtn.disabled = false;
                submitBtn.style.opacity = '1';
                submitBtn.innerText = 'Send Complaint';
            }
        } catch (error) {
            console.error('Fetch Error:', error);
            alert('Server error. Please check your internet connection.');
            submitBtn.disabled = false;
            submitBtn.style.opacity = '1';
            submitBtn.innerText = 'Send Complaint';
        }
    });
</script>
<%- include('partials/footer') %>
</body>
</html>