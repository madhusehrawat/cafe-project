<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Forgot Password | FullStack Cafe</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        .toast {
            visibility: hidden; min-width: 300px; color: #fff; text-align: center;
            border-radius: 16px; padding: 16px 24px; position: fixed; z-index: 1000;
            left: 50%; bottom: 30px; transform: translateX(-50%); opacity: 0;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1); box-shadow: 0 10px 25px rgba(0,0,0,0.15);
            font-weight: 600;
        }
        .toast.show { visibility: visible; opacity: 1; bottom: 50px; }
        .hidden-step { display: none; }
    </style>
</head>
<body class="bg-[#fcf8f5] font-sans antialiased text-gray-900">

<%- include('partials/navbar', { user: locals.user || null }) %>

<main class="min-h-[calc(100vh-80px)] flex items-center justify-center px-4 py-12">
    <div class="w-full max-w-md bg-white rounded-3xl p-8 md:p-10 shadow-xl border border-gray-100">
        
        <div class="text-center mb-10">
            <div class="inline-flex items-center justify-center w-16 h-16 bg-orange-50 rounded-full mb-4">
                <i class="fas fa-key text-[#e67e22] text-2xl"></i>
            </div>
            <h2 id="formTitle" class="text-3xl font-black text-[#5d4037]">Reset Password</h2>
            <p id="formDesc" class="text-gray-500 text-sm mt-3 leading-relaxed">
                Enter your email and we'll send a verification code to your coffee.
            </p>
        </div>

        <form id="step1Form" class="space-y-6">
            <div class="space-y-1">
                <label class="text-[11px] font-black uppercase tracking-widest text-gray-400 ml-1">Email Address</label>
                <div class="relative group">
                    <span class="absolute inset-y-0 left-0 pl-4 flex items-center text-gray-400 group-focus-within:text-[#e67e22]">
                        <i class="fas fa-envelope"></i>
                    </span>
                    <input type="email" id="email" placeholder="name@example.com" required
                        class="w-full pl-11 pr-4 py-3.5 bg-gray-50 border border-gray-100 rounded-2xl outline-none focus:border-[#e67e22] focus:ring-4 focus:ring-orange-50 transition-all">
                </div>
            </div>
            <button type="submit" id="sendOtpBtn"
                class="w-full bg-[#5d4037] text-white py-4 rounded-2xl font-bold text-lg shadow-lg hover:bg-[#4a332c] active:scale-[0.98] transition-all flex items-center justify-center gap-3">
                Send Verification Code
                <i class="fas fa-paper-plane text-sm"></i>
            </button>
        </form>

        <form id="step2Form" class="space-y-6 hidden-step">
            <div class="space-y-4">
                <div class="space-y-1">
                    <label class="text-[11px] font-black uppercase tracking-widest text-gray-400 ml-1">6-Digit Code</label>
                    <input type="text" id="otp" placeholder="123456" maxlength="6" required
                        class="w-full px-4 py-3.5 bg-gray-50 border border-gray-100 rounded-2xl outline-none focus:border-[#e67e22] text-center text-2xl tracking-[1em] font-bold">
                </div>
                <div class="space-y-1">
                    <label class="text-[11px] font-black uppercase tracking-widest text-gray-400 ml-1">New Password</label>
                    <input type="password" id="newPassword" placeholder="••••••••" required
                        class="w-full px-4 py-3.5 bg-gray-50 border border-gray-100 rounded-2xl outline-none focus:border-[#e67e22]">
                </div>
            </div>
            <button type="submit" id="resetBtn"
                class="w-full bg-[#e67e22] text-white py-4 rounded-2xl font-bold text-lg shadow-lg hover:bg-[#d35400] active:scale-[0.98] transition-all flex items-center justify-center gap-3">
                Update Password
                <i class="fas fa-check-circle text-sm"></i>
            </button>
        </form>

        <div class="mt-8 text-center border-t border-gray-50 pt-6">
            <a href="/login" class="text-[#e67e22] font-black hover:underline flex items-center justify-center gap-2 text-sm uppercase tracking-wider">
                <i class="fas fa-arrow-left text-xs"></i> Back to Login
            </a>
        </div>
    </div>
</main>

<div id="toast" class="toast"></div>

<script>
    const step1Form = document.getElementById('step1Form');
    const step2Form = document.getElementById('step2Form');
    const formTitle = document.getElementById('formTitle');
    const formDesc = document.getElementById('formDesc');
    const toast = document.getElementById('toast');

    function showNotification(message, isError = true) {
        toast.innerText = message;
        toast.style.backgroundColor = isError ? "#d32f2f" : "#43a047";
        toast.classList.add("show");
        setTimeout(() => { toast.classList.remove("show"); }, 3500);
    }

    // HANDLER 1: Send OTP
    step1Form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const email = document.getElementById('email').value;
        const btn = document.getElementById('sendOtpBtn');
        
        btn.disabled = true;
        btn.innerHTML = `<i class="fas fa-spinner fa-spin"></i> Sending Code...`;

        try {
            const res = await fetch('/forgot-password', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ email })
            });
            const data = await res.json();

            if (data.success) {
                showNotification("Code sent! Check your inbox.", false);
                // Switch Forms
                step1Form.classList.add('hidden-step');
                step2Form.classList.remove('hidden-step');
                formTitle.innerText = "Verify Code";
                formDesc.innerText = `We sent a code to ${email}. Enter it below with your new password.`;
            } else {
                showNotification(data.error || "Email not found.");
                btn.disabled = false;
                btn.innerHTML = `Send Verification Code <i class="fas fa-paper-plane text-sm"></i>`;
            }
        } catch (err) {
            showNotification("Connection error.");
            btn.disabled = false;
        }
    });

    // HANDLER 2: Verify & Reset
    step2Form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const email = document.getElementById('email').value;
        const otp = document.getElementById('otp').value;
        const newPassword = document.getElementById('newPassword').value;
        const btn = document.getElementById('resetBtn');

        btn.disabled = true;
        btn.innerHTML = `<i class="fas fa-spinner fa-spin"></i> Resetting...`;

        try {
            const res = await fetch('/reset-password-verify', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ email, otp, newPassword })
            });
            const data = await res.json();

            if (data.success) {
                showNotification("Success! Redirecting to login...", false);
                setTimeout(() => { window.location.href = "/login"; }, 2000);
            } else {
                showNotification(data.error || "Invalid code.");
                btn.disabled = false;
                btn.innerHTML = `Update Password <i class="fas fa-check-circle text-sm"></i>`;
            }
        } catch (err) {
            showNotification("Connection error.");
            btn.disabled = false;
        }
    });
</script>
</body>
</html>