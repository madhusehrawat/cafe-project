<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FullStack Cafe | Products</title>
    
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"/>

    <script>
        // Extending Tailwind with your Cafe Brand Colors
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        cafe: {
                            main: '#4e342e',
                            accent: '#e67e22',
                            bg: '#fdf5e6',
                        }
                    },
                    fontFamily: {
                        sans: ['Poppins', 'sans-serif'],
                        serif: ['Playfair Display', 'serif'],
                    }
                }
            }
        }
    </script>

  <style>
    .category-btn {
      /* Added 'inline-block' for transform and 'text-cafe-main' as base color */
      display: inline-block;
      padding: 0.5rem 1.25rem;
      border-radius: 9999px;
      border: 2px solid #4e342e;
      color: #4e342e;
      font-weight: 600;
      transition: all 300ms;
      cursor: pointer;
    }

    /* Use :hover and :focus for accessibility */
    .category-btn:hover {
      background-color: #4e342e;
      color: white;
      transform: translateY(-0.125rem);
      box-shadow: 0 10px 15px -3px rgba(78, 52, 46, 0.2), 0 4px 6px -4px rgba(78, 52, 46, 0.2);
    }

    /* The .active class needs to be explicit so it stays brown after the click */
    .category-btn.active {
      background-color: #4e342e;
      color: white;
      box-shadow: none;
      transform: translateY(0) !important;
    }
  </style>
</head>
<body class="bg-cafe-bg text-slate-800 font-sans overflow-x-hidden">

<%- include('partials/navbar', { user }) %>

<div id="app-content">
    <header class="text-center py-12 px-5 bg-gradient-to-b from-purple-50 to-cafe-bg">
        <h1 class="font-serif text-cafe-main text-4xl md:text-5xl font-bold">FullStack Cafe Menu</h1>
        <p class="text-stone-600 mt-2">Premium handcrafted bites and beverages.</p>
    </header>

    <div class="category-tabs flex justify-center flex-wrap gap-3 mb-8 px-4">
        <% ['All', 'Coffee', 'Drinks', 'Junk Food', 'Salad', 'Dessert'].forEach(cat => {
            const val = cat === 'All' ? '' : cat.toLowerCase();
            const isActive = (locals.category || '') === val;
        %>
            <button class="category-btn <%= isActive ? 'active' : 'text-cafe-main' %>" 
                    onclick="loadProducts({category: '<%= val %>', page: 1})">
                <%= cat %>
            </button>
        <% }) %>
    </div>

    <div class="flex justify-center flex-wrap gap-4 mb-6 px-4">
        <select onchange="loadProducts({availability: this.value, page: 1})" 
                class="bg-white border border-gray-200 rounded-full px-4 py-2 font-semibold text-cafe-main shadow-sm focus:outline-none focus:ring-2 focus:ring-cafe-main">
            <option value="" <%= !locals.availability ? 'selected' : '' %>>All Availability</option>
            <option value="instock" <%= locals.availability === 'instock' ? 'selected' : '' %>>In Stock</option>
            <option value="outofstock" <%= locals.availability === 'outofstock' ? 'selected' : '' %>>Out of Stock</option>
        </select>

        <select onchange="loadProducts({sort: this.value, page: 1})" 
                class="bg-white border border-gray-200 rounded-full px-4 py-2 font-semibold text-cafe-main shadow-sm focus:outline-none focus:ring-2 focus:ring-cafe-main">
            <option value="newest" <%= (locals.sort || 'newest') === 'newest' ? 'selected' : '' %>>Newest First</option>
            <option value="priceAsc" <%= locals.sort === 'priceAsc' ? 'selected' : '' %>>Price: Low to High</option>
            <option value="priceDesc" <%= locals.sort === 'priceDesc' ? 'selected' : '' %>>Price: High to Low</option>
        </select>
    </div>

    <div class="relative max-w-md mx-auto mb-10 px-4">
        <input type="text" id="searchInput" placeholder="Search menu..." value="<%= locals.search || '' %>" 
               onkeyup="if(event.key==='Enter') triggerSearch()"
               class="w-full px-6 py-3 rounded-full border border-gray-200 shadow-md focus:outline-none focus:ring-2 focus:ring-cafe-main">
        <button onclick="triggerSearch()" class="absolute right-6 top-1/2 -translate-y-1/2 bg-cafe-accent text-white px-4 py-1.5 rounded-full hover:brightness-110 transition">
            <i class="fas fa-search"></i>
        </button>
    </div>

    <div id="refresh-zone">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8 max-w-7xl mx-auto px-6 mb-12">
            <% if (locals.items && items.length > 0) { %>
                <% items.forEach(p => { const isOut = p.countInStock <= 0; %>
                    <div class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 cursor-pointer relative flex flex-col group"
                         onclick="openProductModal('<%= p._id %>', '<%= p.name %>', '<%= p.price %>', '<%= p.image %>', `<%= p.description %>`, <%= isOut %>, <%= p.countInStock %>)">
                        
                        <div class="relative h-48 overflow-hidden bg-gray-50">
                            <% if (isOut) { %>
                                <div class="absolute inset-0 bg-white/70 backdrop-blur-[2px] flex items-center justify-center z-10 font-bold text-red-600 uppercase tracking-widest">
                                    Sold Out
                                </div>
                            <% } %>
                            <img src="/images/<%= p.image %>" alt="<%= p.name %>" 
                                 class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
                                 onerror="this.src='/images/default.png'">
                        </div>

                        <div class="p-5 flex-grow">
                            <% if (isOut) { %>
                                <span class="bg-red-50 text-red-700 text-[10px] px-3 py-1 rounded-full uppercase font-bold border border-red-100 mb-2 inline-block">Out of Stock</span>
                            <% } %>
                            <h3 class="text-lg font-bold text-slate-800"><%= p.name %></h3>
                            <div class="text-xl font-bold text-cafe-accent mt-1 mb-4">₹<%= p.price %></div>
                            
                            <button class="w-full py-2.5 rounded-xl font-bold flex items-center justify-center gap-2 transition-colors duration-300 <%= isOut ? 'bg-gray-300 text-gray-500 cursor-not-allowed' : 'bg-cafe-main text-white hover:bg-stone-900' %>"
                                    <%= isOut ? 'disabled' : '' %> 
                                    onclick="event.stopPropagation(); addToCart({productId: '<%= p._id %>', name: '<%= p.name %>', price: <%= p.price %>, image: '<%= p.image %>', countInStock: <%= p.countInStock %>}, 1)">
                                <i class="fas <%= isOut ? 'fa-bell' : 'fa-plus' %>"></i> 
                                <%= isOut ? 'Notify' : 'Add to Bag' %>
                            </button>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="col-span-full text-center py-20 opacity-40">
                    <i class="fas fa-search text-6xl mb-4 block"></i>
                    <p class="text-xl">No products found.</p>
                </div>
            <% } %>
        </div>

        <% if (locals.totalPages > 1) { %>
            <div class="flex items-center justify-center gap-6 mb-20">
                <button class="w-12 h-12 rounded-full bg-white border border-gray-200 flex items-center justify-center text-cafe-main shadow hover:bg-cafe-main hover:text-white disabled:opacity-30 transition-all"
                        <%= currentPage === 1 ? 'disabled' : '' %> onclick="loadProducts({page: <%= currentPage - 1 %>})">
                    <i class="fas fa-chevron-left"></i>
                </button>
                <div class="bg-white px-6 py-2 rounded-full shadow font-bold text-lg">
                    <span><%= currentPage %></span>
                    <span class="mx-2 text-gray-300">/</span>
                    <span><%= totalPages %></span>
                </div>
                <button class="w-12 h-12 rounded-full bg-white border border-gray-200 flex items-center justify-center text-cafe-main shadow hover:bg-cafe-main hover:text-white disabled:opacity-30 transition-all"
                        <%= currentPage === totalPages ? 'disabled' : '' %> onclick="loadProducts({page: <%= currentPage + 1 %>})">
                    <i class="fas fa-chevron-right"></i>
                </button>
            </div>
        <% } %>
    </div>
</div>

<div id="productModal" class="fixed inset-0 bg-black/50 backdrop-blur-md hidden items-center justify-center z-[2000] p-4" onclick="closeModal()">
    <div class="bg-white w-full max-w-3xl rounded-[2rem] p-8 md:p-12 relative flex flex-col md:flex-row gap-10 animate-[modalPop_0.4s_ease]" onclick="event.stopPropagation()">
        <div class="w-full md:w-72 h-72 rounded-2xl overflow-hidden shrink-0">
            <img id="modalImg" src="" class="w-full h-full object-cover">
        </div>
        <div class="flex-grow">
            <h2 id="modalTitle" class="text-3xl font-bold text-slate-800"></h2>
            <p id="modalDescription" class="text-stone-500 leading-relaxed my-4"></p>
            
            <div id="qtyBox" class="flex items-center gap-4 bg-gray-50 p-2 rounded-2xl w-fit mb-6">
                <button class="w-9 h-9 bg-white rounded-full border shadow-sm hover:bg-gray-100 font-bold" onclick="updateModalQty(-1)">-</button>
                <span id="modalQty" class="font-bold text-xl min-w-[24px] text-center">1</span>
                <button class="w-9 h-9 bg-white rounded-full border shadow-sm hover:bg-gray-100 font-bold" onclick="updateModalQty(1)">+</button>
            </div>

            <div id="modalPrice" class="text-3xl font-bold text-cafe-main"></div>
            <button id="modalAddBtn" class="w-full h-14 mt-8 bg-cafe-main text-white rounded-2xl font-bold text-lg hover:brightness-110 transition shadow-lg shadow-cafe-main/20"></button>
        </div>
    </div>
</div>

<div id="toast-container" class="fixed bottom-8 right-8 z-[9999] flex flex-col gap-3"></div>

<script>
    const CART_KEY = 'cafe_cart';
    let currentQty = 1;
    let currentBasePrice = 0;
    let currentMaxStock = 0;
    let currentModalProductId = null;
    let currentModalItem = {};

   function showToast(msg) {
        const container = document.getElementById('toast-container');
        const t = document.createElement('div');
        t.className = 'bg-cafe-main text-white px-6 py-4 rounded-xl shadow-2xl border-l-4 border-cafe-accent animate-[slideIn_0.4s_forwards] font-medium';
        t.innerText = msg;
        container.appendChild(t);
        setTimeout(() => {
            t.style.opacity = '0';
            t.style.transition = '0.5s';
            setTimeout(() => t.remove(), 500);
        }, 3000);
    }

    // Unified Add To Cart Logic
    function addToCart(product, qtyToAdd) {
        let cart = JSON.parse(localStorage.getItem(CART_KEY)) || [];
        const existing = cart.find(item => item.productId === product.productId);

        if (existing) {
            if (existing.quantity + qtyToAdd > product.countInStock) {
                showToast(`Limit reached! Only ${product.countInStock} available.`);
                return;
            }
            existing.quantity += qtyToAdd;
        } else {
            cart.push({
                productId: product.productId,
                name: product.name,
                price: product.price,
                image: product.image,
                countInStock: product.countInStock,
                quantity: qtyToAdd
            });
        }
        
        localStorage.setItem(CART_KEY, JSON.stringify(cart));
        showToast(`Added ${qtyToAdd} ${product.name} to tray!`);
        if(window.updateCartBadge) window.updateCartBadge();
    }

  async function loadProducts(params = {}) {
    const refreshZone = document.getElementById('refresh-zone');
    const categoryContainer = document.querySelector('.category-tabs');
    
    // 1. Manage URL Parameters
    const urlParams = new URLSearchParams(window.location.search);
    
    Object.keys(params).forEach(k => {
        if (params[k] === '' || params[k] === undefined) {
            urlParams.delete(k);
        } else {
            urlParams.set(k, params[k]);
        }
    });

    const newUrl = `/products?${urlParams.toString()}`;

    // 2. Visual Feedback (Start Loading)
    refreshZone.style.opacity = '0.4';
    refreshZone.style.pointerEvents = 'none'; // Prevent double-clicks while loading

    try {
        const res = await fetch(newUrl);
        if (!res.ok) throw new Error('Network response was not ok');
        
        const html = await res.text();
        const doc = new DOMParser().parseFromString(html, 'text/html');
        
        // 3. Update the Product Grid & Pagination
        const newContent = doc.getElementById('refresh-zone').innerHTML;
        refreshZone.innerHTML = newContent;
        
        // 4. Update the Category Tabs (Crucial for the Brown Active State)
        const newTabs = doc.querySelector('.category-tabs').innerHTML;
        categoryContainer.innerHTML = newTabs;

        // 5. Update Search Input (Keep it in sync with the URL)
        const searchInput = document.getElementById('searchInput');
        if (searchInput) {
            searchInput.value = urlParams.get('search') || '';
        }
        
        // 6. Push state to Browser History
        window.history.pushState({}, '', newUrl);

        // 7. Smoothly scroll back to the top of the menu
        window.scrollTo({ top: 0, behavior: 'smooth' });

    } catch (e) { 
        console.error("Failed to load products:", e);
        showToast("Connection error. Please try again.");
    } finally {
        // 8. Visual Feedback (End Loading)
        refreshZone.style.opacity = '1';
        refreshZone.style.pointerEvents = 'auto';
    }
}

    function triggerSearch() {
        loadProducts({ search: document.getElementById('searchInput').value, page: 1 });
    }

    function openProductModal(id, name, price, image, desc, isOut, maxStock) {
        currentBasePrice = parseFloat(price);
        currentMaxStock = parseInt(maxStock);
        currentQty = 1;
        currentModalItem = { productId: id, name, price: currentBasePrice, image, countInStock: currentMaxStock };

        document.getElementById('modalTitle').innerText = name;
        document.getElementById('modalPrice').innerText = `₹${price}`;
        document.getElementById('modalImg').src = `/images/${image}`;
        document.getElementById('modalQty').innerText = currentQty;
        document.getElementById('modalDescription').innerText = desc;
        
        const btn = document.getElementById('modalAddBtn');
        if(isOut) {
            btn.disabled = true; btn.innerHTML = 'Notify Me';
            document.getElementById('qtyBox').style.display = 'none';
        } else {
            btn.disabled = false; btn.innerHTML = 'Add to Bag';
            document.getElementById('qtyBox').style.display = 'flex';
            btn.onclick = () => { 
                addToCart(currentModalItem, currentQty); 
                closeModal(); 
            };
        }
        document.getElementById('productModal').style.display = 'flex';
    }

    function updateModalQty(val) {
        let next = currentQty + val;
        if(next > currentMaxStock) { showToast("Stock limit reached."); return; }
        currentQty = Math.max(1, next);
        document.getElementById('modalQty').innerText = currentQty;
        document.getElementById('modalPrice').innerText = `₹${(currentBasePrice * currentQty).toFixed(2)}`;
    }

    function closeModal() { document.getElementById('productModal').style.display = 'none'; }
</script>

<%- include('partials/footer') %>
</body>
</html>