<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FullStack Cafe | Products</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"/>

    <style>
        :root {
            --main: #4e342e;
            --accent: #e67e22; /* Matches your accent orange */
            --bg: #fdf5e6;
            --white: #ffffff;
            --text: #2c3e50;
            --outOfStock: #95a5a6;
            --shadow: 0 10px 30px rgba(0,0,0,0.08);
            --transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        }

        body { font-family: 'Poppins', sans-serif; background: var(--bg); margin: 0; color: var(--text); overflow-x: hidden; }

        .header { text-align: center; padding: 50px 20px 30px; background: linear-gradient(to bottom, #f3e5f5, var(--bg)); }
        .header h1 { font-family: 'Playfair Display', serif; color: var(--main); font-size: 2.8rem; margin: 0; }
        .header p { color: #6d4c41; margin-top: 5px; }

        .category-tabs { text-align: center; margin-bottom: 20px; display: flex; justify-content: center; flex-wrap: wrap; gap: 10px; }
        .category-tabs button { padding: 8px 20px; border-radius: 30px; border: 2px solid var(--main); cursor: pointer; background: transparent; color: var(--main); font-weight: 600; transition: var(--transition); }
        .category-tabs button.active { background: var(--main); color: white; }

        .filter-row { display: flex; justify-content: center; gap: 15px; margin-bottom: 25px; flex-wrap: wrap; }
        .styled-select { padding: 10px 15px; border-radius: 20px; border: 1px solid #ddd; background: white; font-family: inherit; font-weight: 600; color: var(--main); cursor: pointer; outline: none; box-shadow: var(--shadow); }

        .filters { display: flex; justify-content: center; max-width: 450px; margin: 0 auto 40px; position: relative; }
        .filters input { padding: 12px 20px; width: 100%; border-radius: 40px; border: 1px solid #ddd; outline: none; box-shadow: var(--shadow); }
        .filters button { position: absolute; right: 5px; top: 4px; padding: 8px 15px; background: var(--accent); color: white; border-radius: 30px; border: none; cursor: pointer; }

        .product-grid { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 25px; padding: 20px; transition: opacity 0.3s ease; }
        .card { background: var(--white); border-radius: 15px; overflow: hidden; box-shadow: var(--shadow); transition: var(--transition); display: flex; flex-direction: column; cursor: pointer; position: relative; }
        .card:hover { transform: translateY(-5px); }
        .card-image-container { position: relative; width: 100%; height: 180px; overflow: hidden; background: #f9f9f9; }
        .card img { width: 100%; height: 100%; object-fit: cover; transition: 0.8s; }
        .card:hover img { transform: scale(1.08); }
        .sold-out-overlay { position: absolute; inset: 0; background: rgba(255, 255, 255, 0.7); display: flex; justify-content: center; align-items: center; z-index: 10; font-weight: 700; color: #c0392b; text-transform: uppercase; backdrop-filter: blur(2px); }

        .card-body { padding: 18px; text-align: left; }
        .stock-badge { display: inline-block; font-size: 0.7rem; padding: 4px 12px; border-radius: 50px; margin-bottom: 10px; text-transform: uppercase; font-weight: 600; }
        .out-of-stock { background: #f2dede; color: #a94442; border: 1px solid #ebccd1; }

        .price { color: var(--accent); font-size: 1.25rem; font-weight: 700; margin-bottom: 15px; }

        .buy-btn { background: var(--main); color: white; border: none; padding: 10px; border-radius: 10px; cursor: pointer; width: 100%; font-weight: 600; display: flex; align-items: center; justify-content: center; gap: 8px; transition: 0.3s; }
        .buy-btn:disabled { background: var(--outOfStock); cursor: not-allowed; }

        .pagination { display: flex; align-items: center; justify-content: center; gap: 20px; margin: 50px 0; }
        .pg-arrow { background: var(--white); border: 1px solid #ddd; width: 45px; height: 45px; border-radius: 50%; display: flex; align-items: center; justify-content: center; cursor: pointer; color: var(--main); transition: var(--transition); box-shadow: var(--shadow); outline: none; }
        .pg-arrow:hover:not(:disabled) { background: var(--main); color: white; border-color: var(--main); transform: scale(1.1); }
        .pg-arrow:disabled { opacity: 0.4; cursor: not-allowed; box-shadow: none; }
        .pg-info { font-weight: 600; font-size: 1.1rem; display: flex; align-items: center; gap: 8px; background: var(--white); padding: 8px 20px; border-radius: 30px; box-shadow: var(--shadow); }

        .modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.5); display: none; justify-content: center; align-items: center; z-index: 2000; backdrop-filter: blur(8px); }
        .modal-content { background: #fff; width: 95%; max-width: 750px; border-radius: 30px; padding: 40px; position: relative; display: flex; flex-direction: column; md-flex-direction: row; gap: 40px; animation: modalPop 0.4s ease; }
        @media (min-width: 768px) { .modal-content { flex-direction: row; } }
        .modal-img-wrapper { flex: 0 0 280px; height: 280px; border-radius: 20px; overflow: hidden; }
        .modal-img-wrapper img { width: 100%; height: 100%; object-fit: cover; }
        .modal-details { flex: 1; }
        .qty-box { display: flex; align-items: center; gap: 15px; margin: 20px 0; background: #f9f9f9; padding: 10px; border-radius: 15px; width: fit-content; }
        .qty-btn { background: white; border: 1px solid #ddd; width: 35px; height: 35px; border-radius: 50%; cursor: pointer; font-weight: 700; transition: 0.2s; }

        #toast-container { position: fixed; bottom: 30px; right: 30px; z-index: 9999; display: flex; flex-direction: column; gap: 10px; }
        .toast { background: var(--main); color: white; padding: 15px 25px; border-radius: 12px; box-shadow: 0 10px 25px rgba(0,0,0,0.2); animation: slideIn 0.4s forwards; border-left: 5px solid var(--accent); font-weight: 500; }
        @keyframes slideIn { from { transform: translateX(110%); } to { transform: translateX(0); } }
        @keyframes modalPop { from { transform: scale(0.9); opacity: 0; } to { transform: scale(1); opacity: 1; } }
    </style>
</head>
<body>

<%- include('partials/navbar', { user }) %>

<div id="app-content">
    <div class="header">
        <h1>FullStack Cafe Menu</h1>
        <p>Premium handcrafted bites and beverages.</p>
    </div>

    <div class="category-tabs">
        <% ['All', 'Coffee', 'Drinks', 'Junk Food', 'Salad', 'Dessert'].forEach(cat => {
            const val = cat === 'All' ? '' : cat.toLowerCase();
        %>
            <button class="<%= (locals.category || '') === val ? 'active' : '' %>"
                    onclick="loadProducts({category: '<%= val %>', page: 1})"><%= cat %></button>
        <% }) %>
    </div>

    <div class="filter-row">
        <select id="avail-dropdown" class="styled-select" onchange="loadProducts({availability: this.value, page: 1})">
            <option value="" <%= !locals.availability ? 'selected' : '' %>>All Availability</option>
            <option value="instock" <%= locals.availability === 'instock' ? 'selected' : '' %>>In Stock</option>
            <option value="outofstock" <%= locals.availability === 'outofstock' ? 'selected' : '' %>>Out of Stock</option>
        </select>

        <select id="sort-dropdown" class="styled-select" onchange="loadProducts({sort: this.value, page: 1})">
            <option value="newest" <%= (locals.sort || 'newest') === 'newest' ? 'selected' : '' %>>Newest First</option>
            <option value="priceAsc" <%= locals.sort === 'priceAsc' ? 'selected' : '' %>>Price: Low to High</option>
            <option value="priceDesc" <%= locals.sort === 'priceDesc' ? 'selected' : '' %>>Price: High to Low</option>
        </select>
    </div>

    <div class="filters">
        <input type="text" id="searchInput" placeholder="Search menu..." value="<%= locals.search || '' %>" onkeyup="if(event.key==='Enter') triggerSearch()">
        <button onclick="triggerSearch()"><i class="fas fa-search"></i></button>
    </div>

    <div id="refresh-zone">
        <div class="product-grid" id="productGrid">
            <% if (locals.items && items.length > 0) { %>
                <% items.forEach(p => {
                    const isOut = p.countInStock <= 0;
                %>
                    <div class="card" onclick="openProductModal('<%= p._id %>', '<%= p.name %>', '<%= p.price %>', '<%= p.image %>', `<%= p.description %>`, <%= isOut %>, <%= p.countInStock %>)">
                        <div class="card-image-container">
                            <% if (isOut) { %><div class="sold-out-overlay">Sold Out</div><% } %>
                            <img src="/images/<%= p.image %>" alt="<%= p.name %>" onerror="this.src='/images/default.png'">
                        </div>
                        <div class="card-body">
                            <% if (isOut) { %>
                                <span class="stock-badge out-of-stock">Out of Stock</span>
                            <% } %>
                            <h3><%= p.name %></h3>
                            <div class="price">₹<%= p.price %></div>
                            <button class="buy-btn" <%= isOut ? 'disabled' : '' %> 
                                onclick="event.stopPropagation(); addToCart({productId: '<%= p._id %>', name: '<%= p.name %>', price: <%= p.price %>, image: '<%= p.image %>', countInStock: <%= p.countInStock %>}, 1)">
                                <i class="fas <%= isOut ? 'fa-bell' : 'fa-plus' %>"></i> <%= isOut ? 'Notify' : 'Add to Bag' %>
                            </button>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div style="grid-column: 1/-1; text-align: center; padding: 80px; font-size: 1.2rem; color: #999;">
                    <i class="fas fa-search" style="font-size: 3rem; display: block; margin-bottom: 20px; opacity: 0.3;"></i>
                    No products found.
                </div>
            <% } %>
        </div>

        <% if (locals.totalPages > 1) { %>
            <div class="pagination">
                <button class="pg-arrow" <%= currentPage === 1 ? 'disabled' : '' %> onclick="loadProducts({page: <%= currentPage - 1 %>})">
                    <i class="fas fa-chevron-left"></i>
                </button>
                <div class="pg-info">
                    <span class="pg-current"><%= currentPage %></span>
                    <span>/</span>
                    <span class="pg-total"><%= totalPages %></span>
                </div>
                <button class="pg-arrow" <%= currentPage === totalPages ? 'disabled' : '' %> onclick="loadProducts({page: <%= currentPage + 1 %>})">
                    <i class="fas fa-chevron-right"></i>
                </button>
            </div>
        <% } %>
    </div>
</div>

<div id="productModal" class="modal-overlay" onclick="closeModal()">
    <div class="modal-content" onclick="event.stopPropagation()">
        <div class="modal-img-wrapper"><img id="modalImg" src=""></div>
        <div class="modal-details">
            <h2 id="modalTitle" class="text-2xl font-bold"></h2>
            <p id="modalDescription" style="color: #666; line-height: 1.6; margin: 15px 0;"></p>
            <div class="qty-box" id="qtyBox">
                <button class="qty-btn" onclick="updateModalQty(-1)">-</button>
                <span id="modalQty" style="font-weight: 600; font-size: 1.2rem; min-width: 20px; text-align: center;">1</span>
                <button class="qty-btn" onclick="updateModalQty(1)">+</button>
            </div>
            <div class="price" id="modalPrice" style="font-size: 1.8rem; margin-top: 10px;"></div>
            <button id="modalAddBtn" class="buy-btn" style="height: 55px; margin-top: 25px; font-size: 1.1rem;"></button>
        </div>
    </div>
</div>

<div id="toast-container"></div>

<script>
    const CART_KEY = 'cafe_cart';
    let currentQty = 1;
    let currentBasePrice = 0;
    let currentMaxStock = 0;
    let currentModalProductId = null;
    let currentModalItem = {};

    function showToast(msg) {
        const container = document.getElementById('toast-container');
        const t = document.createElement('div');
        t.className = 'toast';
        t.innerText = msg;
        container.appendChild(t);
        setTimeout(() => {
            t.style.opacity = '0';
            setTimeout(() => t.remove(), 500);
        }, 3000);
    }

    // Unified Add To Cart Logic
    function addToCart(product, qtyToAdd) {
        let cart = JSON.parse(localStorage.getItem(CART_KEY)) || [];
        const existing = cart.find(item => item.productId === product.productId);

        if (existing) {
            if (existing.quantity + qtyToAdd > product.countInStock) {
                showToast(`Limit reached! Only ${product.countInStock} available.`);
                return;
            }
            existing.quantity += qtyToAdd;
        } else {
            cart.push({
                productId: product.productId,
                name: product.name,
                price: product.price,
                image: product.image,
                countInStock: product.countInStock,
                quantity: qtyToAdd
            });
        }
        
        localStorage.setItem(CART_KEY, JSON.stringify(cart));
        showToast(`Added ${qtyToAdd} ${product.name} to tray!`);
        if(window.updateCartBadge) window.updateCartBadge();
    }

    async function loadProducts(params = {}) {
        const refreshZone = document.getElementById('refresh-zone');
        const urlParams = new URLSearchParams(window.location.search);
        Object.keys(params).forEach(k => {
            if (params[k] === '') urlParams.delete(k);
            else urlParams.set(k, params[k]);
        });
        const newUrl = `/products?${urlParams.toString()}`;
        refreshZone.style.opacity = '0.4';
        try {
            const res = await fetch(newUrl);
            const html = await res.text();
            const doc = new DOMParser().parseFromString(html, 'text/html');
            refreshZone.innerHTML = doc.getElementById('refresh-zone').innerHTML;
            window.history.pushState({}, '', newUrl);
        } catch (e) { console.error(e); }
        refreshZone.style.opacity = '1';
    }

    function triggerSearch() {
        loadProducts({ search: document.getElementById('searchInput').value, page: 1 });
    }

    function openProductModal(id, name, price, image, desc, isOut, maxStock) {
        currentBasePrice = parseFloat(price);
        currentMaxStock = parseInt(maxStock);
        currentQty = 1;
        currentModalItem = { productId: id, name, price: currentBasePrice, image, countInStock: currentMaxStock };

        document.getElementById('modalTitle').innerText = name;
        document.getElementById('modalPrice').innerText = `₹${price}`;
        document.getElementById('modalImg').src = `/images/${image}`;
        document.getElementById('modalQty').innerText = currentQty;
        document.getElementById('modalDescription').innerText = desc;
        
        const btn = document.getElementById('modalAddBtn');
        if(isOut) {
            btn.disabled = true; btn.innerHTML = 'Notify Me';
            document.getElementById('qtyBox').style.display = 'none';
        } else {
            btn.disabled = false; btn.innerHTML = 'Add to Bag';
            document.getElementById('qtyBox').style.display = 'flex';
            btn.onclick = () => { 
                addToCart(currentModalItem, currentQty); 
                closeModal(); 
            };
        }
        document.getElementById('productModal').style.display = 'flex';
    }

    function updateModalQty(val) {
        let next = currentQty + val;
        if(next > currentMaxStock) { showToast("Stock limit reached."); return; }
        currentQty = Math.max(1, next);
        document.getElementById('modalQty').innerText = currentQty;
        document.getElementById('modalPrice').innerText = `₹${(currentBasePrice * currentQty).toFixed(2)}`;
    }

    function closeModal() { document.getElementById('productModal').style.display = 'none'; }
</script>

<%- include('partials/footer') %>
</body>
</html>