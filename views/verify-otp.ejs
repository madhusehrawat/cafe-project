<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Verify OTP | FullStack Cafe</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        .toast {
            visibility: hidden;
            min-width: 300px;
            color: #fff;
            text-align: center;
            border-radius: 16px;
            padding: 16px 24px;
            position: fixed;
            z-index: 1000;
            left: 50%;
            bottom: 30px;
            transform: translateX(-50%);
            opacity: 0;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            box-shadow: 0 10px 25px rgba(0,0,0,0.15);
            font-weight: 600;
        }
        .toast.show { visibility: visible; opacity: 1; bottom: 50px; }
        
        /* Character spacing for OTP input */
        .otp-letter-spacing {
            letter-spacing: 0.75rem;
            text-indent: 0.75rem;
        }
    </style>
</head>
<body class="bg-[#fcf8f5] font-sans antialiased text-gray-900">

<main class="min-h-screen flex items-center justify-center px-4 py-12">
    
    <div class="w-full max-w-md bg-white rounded-3xl p-8 md:p-10 shadow-xl shadow-brown-100/10 border border-gray-100">
        
        <div class="text-center mb-8">
            <div class="inline-flex items-center justify-center w-16 h-16 bg-orange-50 rounded-full mb-4">
                <i class="fas fa-envelope-open-text text-[#e67e22] text-2xl"></i>
            </div>
            <h2 class="text-3xl font-black text-[#5d4037]">Verify Email</h2>
            <p id="instructionText" class="text-gray-500 text-sm mt-3 leading-relaxed italic">
                Enter the 6-digit code sent to your email.
            </p>
        </div>

        <form id="verifyForm" class="space-y-6">
            <div class="space-y-2">
                <label class="text-[11px] font-black uppercase tracking-widest text-gray-400 ml-1">Verification Code</label>
                <input type="text" id="otp" placeholder="000000" maxlength="6" required
                    class="otp-letter-spacing w-full py-4 bg-gray-50 border border-gray-100 rounded-2xl outline-none focus:border-[#e67e22] focus:ring-4 focus:ring-orange-50 transition-all text-center text-2xl font-black text-[#5d4037]">
            </div>

            <button type="submit" id="verifyBtn"
                class="w-full bg-[#5d4037] text-white py-4 rounded-2xl font-bold text-lg shadow-lg shadow-brown-200 hover:bg-[#4a332c] active:scale-[0.98] transition-all flex items-center justify-center gap-3">
                Verify & Create Account
            </button>
        </form>

        <div class="mt-8 text-center pt-6 border-t border-gray-50">
            <div id="resend-section" class="text-sm font-medium text-gray-500">
                <p id="timerText" class="flex items-center justify-center gap-2">
                    <i class="fas fa-clock text-xs"></i> 
                    Resend code in <span id="timer" class="text-[#e67e22] font-bold">30</span>s
                </p>
                <button id="resendBtn" onclick="handleResend(event)" 
                    class="hidden text-[#e67e22] font-black hover:underline uppercase tracking-wider text-xs">
                    <i class="fas fa-redo-alt mr-1"></i> Resend OTP
                </button>
            </div>

            <div class="mt-6">
                <a href="/signup" class="text-gray-400 hover:text-[#5d4037] transition-colors text-sm font-bold flex items-center justify-center gap-2">
                    <i class="fas fa-arrow-left text-xs"></i> Back to Signup
                </a>
            </div>
        </div>
    </div>
</main>

<div id="toast" class="toast"></div>

<script>
    const email = sessionStorage.getItem("verifyEmail");
    const toast = document.getElementById("toast");
    const verifyForm = document.getElementById("verifyForm");
    const verifyBtn = document.getElementById("verifyBtn");
    
    // Redirect if no email context
    if (!email) {
        window.location.href = "/signup";
    } else {
        document.getElementById("instructionText").innerHTML = `Code sent to: <span class="text-[#5d4037] font-bold">${email}</span>`;
    }

    function showNotification(message, isError = true) {
        toast.innerText = message;
        toast.style.backgroundColor = isError ? "#d32f2f" : "#43a047";
        toast.classList.add("show");
        setTimeout(() => { toast.classList.remove("show"); }, 3500);
    }

    verifyForm.addEventListener("submit", async (e) => {
        e.preventDefault();
        const otp = document.getElementById("otp").value;

        verifyBtn.innerHTML = `<i class="fas fa-circle-notch fa-spin"></i> Verifying...`;
        verifyBtn.disabled = true;

        try {
            const res = await fetch("/verify-otp", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ email, otp })
            });

            const data = await res.json();
            if (data.success) {
                showNotification("Account verified! Welcome to the cafe.", false);
                sessionStorage.removeItem("verifyEmail");
                setTimeout(() => { window.location.href = "/login"; }, 2500);
            } else {
                showNotification(data.error || "Invalid OTP code.");
                verifyBtn.innerText = "Verify & Create Account";
                verifyBtn.disabled = false;
            }
        } catch (err) {
            showNotification("Connection error. Please try again.");
            verifyBtn.disabled = false;
            verifyBtn.innerText = "Verify & Create Account";
        }
    });

    // Timer Logic
    let timeLeft = 30;
    const timerSpan = document.getElementById("timer");
    const timerText = document.getElementById("timerText");
    const resendBtn = document.getElementById("resendBtn");

    function startTimer() {
        const countdown = setInterval(() => {
            timeLeft--;
            timerSpan.innerText = timeLeft;
            if (timeLeft <= 0) {
                clearInterval(countdown);
                timerText.classList.add("hidden");
                resendBtn.classList.remove("hidden");
            }
        }, 1000);
    }

    async function handleResend(e) {
        e.preventDefault();
        resendBtn.classList.add("hidden");
        timerText.classList.remove("hidden");
        timerText.innerHTML = `<i class="fas fa-spinner fa-spin mr-2"></i>Sending...`;

        try {
            const res = await fetch("/resend-otp", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ email })
            });
            
            if (res.ok) {
                showNotification("A fresh code has been sent!", false);
                timeLeft = 30;
                timerText.innerHTML = `<i class="fas fa-clock text-xs"></i> Resend code in <span id="timer" class="text-[#e67e22] font-bold">30</span>s`;
                startTimer();
            }
        } catch (err) {
            showNotification("Failed to resend. Check your connection.");
            resendBtn.classList.remove("hidden");
        }
    }

    startTimer();
</script>

</body>
</html>