<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard | FullStack Cafe</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        :root {
            --primary: #e67e22;
            --primary-dark: #d35400;
            --coffee-brown: #5d4037;
        }
        body { font-family: 'Inter', sans-serif; background: #f8fafc; }
        
        /* Fixed Scroll Area for Tables */
        .table-container {
            max-height: 60vh; /* Takes up 60% of the screen height */
            overflow-y: auto;
            border-radius: 0 0 12px 12px;
        }

        /* Keep Table Headers Fixed while scrolling */
        thead th {
            position: sticky;
            top: 0;
            z-index: 20;
            background: #f1f5f9;
            box-shadow: 0 1px 2px rgba(0,0,0,0.1);
        }

        /* Coffee themed Scrollbar */
        .table-container::-webkit-scrollbar { width: 6px; }
        .table-container::-webkit-scrollbar-track { background: #f1f5f9; }
        .table-container::-webkit-scrollbar-thumb { 
            background: var(--coffee-brown); 
            border-radius: 10px; 
        }

        .tabs button.active {
            color: var(--primary);
            border-bottom: 3px solid var(--primary);
        }

        .hidden-item { opacity: 0.5; background: #f1f5f9; }
    </style>
</head>
<body class="p-4 md:p-8">

<div class="max-w-7xl mx-auto">
    <header class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 bg-white p-6 rounded-xl shadow-sm border border-slate-100">
        <div>
            <h1 class="text-2xl font-bold text-slate-800">FullStack Cafe Admin</h1>
            <p class="text-sm text-slate-500">Business insights & menu management</p>
        </div>
        <div class="flex items-center gap-4 mt-4 md:mt-0">
            <a href="/admin/products/add" class="bg-[#e67e22] hover:bg-[#d35400] text-white px-5 py-2.5 rounded-lg font-bold flex items-center gap-2 transition-all shadow-md active:scale-95">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                Add Product
            </a>
            <div class="hidden md:block h-10 w-px bg-slate-200 mx-2"></div>
            <div class="text-right">
                <span class="block text-[10px] text-slate-400 uppercase font-black tracking-widest">Administrator</span>
                <span class="font-bold text-slate-700"><%= user.username %></span> | 
                <a href="/logout" class="text-red-500 hover:text-red-700 text-sm font-bold ml-1">Logout</a>
            </div>
        </div>
    </header>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
        <div class="bg-white p-6 rounded-xl shadow-sm border-t-4 border-green-500">
            <p class="text-xs font-bold text-slate-400 uppercase tracking-wider">Total Revenue</p>
            <h3 class="text-2xl font-bold text-slate-800 mt-1">₹<span id="stat-revenue"><%= stats.totalRevenue %></span></h3>
        </div>
        <div class="bg-white p-6 rounded-xl shadow-sm border-t-4 border-yellow-500">
            <p class="text-xs font-bold text-slate-400 uppercase tracking-wider">Active Orders</p>
            <h3 class="text-2xl font-bold text-slate-800 mt-1" id="stat-active"><%= stats.activeOrders %></h3>
        </div>
        <div class="bg-white p-6 rounded-xl shadow-sm border-t-4 border-orange-500">
            <p class="text-xs font-bold text-slate-400 uppercase tracking-wider">Low Stock Items</p>
            <h3 class="text-2xl font-bold text-slate-800 mt-1" id="stat-low"><%= stats.lowStockCount %></h3>
        </div>
        <div class="bg-white p-6 rounded-xl shadow-sm border-t-4 border-blue-500">
            <p class="text-xs font-bold text-slate-400 uppercase tracking-wider">Total Orders</p>
            <h3 class="text-2xl font-bold text-slate-800 mt-1" id="stat-total"><%= stats.orderCount %></h3>
        </div>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-slate-100 overflow-hidden">
        <div class="flex flex-col md:flex-row items-center justify-between p-4 border-b border-slate-100 bg-slate-50/50 gap-4">
            <div class="tabs flex gap-6">
                <button id="orderTab" onclick="switchView('orders')" class="active pb-2 font-bold text-sm transition-all">Orders Management</button>
                <button id="menuTab" onclick="switchView('menu')" class="pb-2 font-bold text-sm text-slate-400 transition-all">Menu Inventory</button>
            </div>
            <div class="relative w-full md:w-72">
                <input type="text" id="tableSearch" onkeyup="filterTable()" placeholder="Search anything..." class="w-full pl-10 pr-4 py-2 rounded-lg border border-slate-200 focus:ring-2 focus:ring-orange-100 focus:border-orange-400 outline-none text-sm transition-all">
                <svg class="absolute left-3 top-2.5 text-slate-400" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
            </div>
        </div>

        <div id="orders-section" class="table-container">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr>
                        <th class="p-4 text-xs font-bold text-slate-500 uppercase">ID</th>
                        <th class="p-4 text-xs font-bold text-slate-500 uppercase">Customer</th>
                        <th class="p-4 text-xs font-bold text-slate-500 uppercase">Amount</th>
                        <th class="p-4 text-xs font-bold text-slate-500 uppercase">Status</th>
                        <th class="p-4 text-xs font-bold text-slate-500 uppercase text-right">Date</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    <% orders.forEach(order => { %>
                        <tr class="hover:bg-slate-50/80 transition-colors">
                            <td class="p-4 font-mono text-xs text-orange-600 font-bold">#<%= order._id.toString().slice(-6).toUpperCase() %></td>
                            <td class="p-4 text-sm font-semibold text-slate-700"><%= order.user ? order.user.username : 'Guest User' %></td>
                            <td class="p-4 text-sm font-bold text-slate-900">₹<%= order.totalAmount %></td>
                            <td class="p-4">
                                <select onchange="updateOrderStatus('<%= order._id %>', this.value)" class="text-xs font-bold p-1.5 border rounded-md bg-white focus:ring-2 focus:ring-orange-100 outline-none cursor-pointer">
                                    <option value="Pending" <%= order.status === 'Pending' ? 'selected' : '' %>>Pending</option>
                                    <option value="Preparing" <%= order.status === 'Preparing' ? 'selected' : '' %>>Preparing</option>
                                    <option value="Out for Delivery" <%= order.status === 'Out for Delivery' ? 'selected' : '' %>>Out for Delivery</option>
                                    <option value="Delivered" <%= order.status === 'Delivered' ? 'selected' : '' %>>Delivered</option>
                                    <option value="Cancelled" <%= order.status === 'Cancelled' ? 'selected' : '' %>>Cancelled</option>
                                </select>
                            </td>
                            <td class="p-4 text-xs text-slate-400 text-right font-medium"><%= new Date(order.createdAt).toLocaleDateString('en-IN') %></td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>

        <div id="menu-section" class="table-container hidden">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr>
                        <th class="p-4 text-xs font-bold text-slate-500 uppercase">Menu Item</th>
                        <th class="p-4 text-xs font-bold text-slate-500 uppercase">Price</th>
                        <th class="p-4 text-xs font-bold text-slate-500 uppercase">Current Stock</th>
                        <th class="p-4 text-xs font-bold text-slate-500 uppercase">Availability</th>
                        <th class="p-4 text-xs font-bold text-slate-500 uppercase text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    <% products.forEach(product => { %>
                        <tr id="row-<%= product._id %>" class="<%= product.isActive ? '' : 'hidden-item' %> hover:bg-slate-50 transition-all">
                            <td class="p-4 font-bold text-slate-700"><%= product.name %></td>
                            <td class="p-4 text-sm font-bold text-slate-500">₹<%= product.price %></td>
                            <td class="p-4">
                                <input type="number" id="stock-input-<%= product._id %>" value="<%= product.countInStock %>" 
                                       onchange="updateStock('<%= product._id %>')"
                                       class="w-20 p-1.5 border rounded text-center font-bold text-sm focus:border-orange-500 outline-none transition-all">
                            </td>
                            <td class="p-4">
                                <span id="badge-<%= product._id %>" class="px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-tighter text-white <%= product.countInStock > 5 ? 'bg-green-500' : (product.countInStock > 0 ? 'bg-yellow-500' : 'bg-red-500') %>">
                                    <%= !product.isActive ? 'HIDDEN' : (product.countInStock > 5 ? 'AVAILABLE' : (product.countInStock > 0 ? 'LOW STOCK' : 'OUT OF STOCK')) %>
                                </span>
                            </td>
                            <td class="p-4 text-right">
                                <button id="toggle-<%= product._id %>" onclick="toggleProductStatus('<%= product._id %>')" 
                                        class="text-[10px] font-bold px-4 py-1.5 rounded bg-slate-100 border hover:bg-slate-200 transition-all uppercase">
                                    <%= product.isActive ? 'Hide' : 'Show' %>
                                </button>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>
<input type="hidden" id="vapid-public-key" value="<%= publicVapidKey %>">

<script>
    // Tab Switching
    function switchView(view) {
        const orderSec = document.getElementById('orders-section');
        const menuSec = document.getElementById('menu-section');
        const orderTab = document.getElementById('orderTab');
        const menuTab = document.getElementById('menuTab');

        if(view === 'orders') {
            orderSec.classList.remove('hidden');
            menuSec.classList.add('hidden');
            orderTab.classList.add('active', 'text-slate-800');
            menuTab.classList.remove('active', 'text-slate-800');
            menuTab.classList.add('text-slate-400');
        } else {
            menuSec.classList.remove('hidden');
            orderSec.classList.add('hidden');
            menuTab.classList.add('active', 'text-slate-800');
            orderTab.classList.remove('active', 'text-slate-800');
            orderTab.classList.add('text-slate-400');
        }
    }
const VAPID_PUBLIC_KEY = document.getElementById('vapid-public-key').value;

    // Helper function to convert the VAPID key for the browser
    function urlBase64ToUint8Array(base64String) {
        const padding = '='.repeat((4 - base64String.length % 4) % 4);
        const base64 = (base64String + padding).replace(/-/g, '+').replace(/_/g, '/');
        const rawData = window.atob(base64);
        const outputArray = new Uint8Array(rawData.length);
        for (let i = 0; i < rawData.length; ++i) {
            outputArray[i] = rawData.charCodeAt(i);
        }
        return outputArray;
    }

    async function subscribeUser() {
        try {
            // 1. Register Service Worker
            const register = await navigator.serviceWorker.register('/sw.js', {
                scope: '/'
            });

            // 2. Wait for registration to be ready
            const subscription = await register.pushManager.subscribe({
                userVisibleOnly: true,
                applicationServerKey: urlBase64ToUint8Array(VAPID_PUBLIC_KEY)
            });

            // 3. Send subscription to your backend
            await fetch('/subscribe', {
                method: 'POST',
                body: JSON.stringify(subscription),
                headers: { 'Content-Type': 'application/json' }
            });
            
            console.log("Push Registration Successful");
        } catch (err) {
            console.error("Failed to subscribe user:", err);
        }
    }

    // Check for browser support and trigger
    if ('serviceWorker' in navigator && 'PushManager' in window) {
        // We trigger this on load, but in production, 
        // you might want to trigger it via a "Enable Notifications" button
        window.addEventListener('load', () => {
            subscribeUser();
        });
    }

    // Dynamic Search
    function filterTable() {
        const query = document.getElementById('tableSearch').value.toLowerCase();
        document.querySelectorAll('tbody tr').forEach(row => {
            row.style.display = row.innerText.toLowerCase().includes(query) ? '' : 'none';
        });
    }

    // AJAX: Update Stock Level
    async function updateStock(productId) {
        const input = document.getElementById(`stock-input-${productId}`);
        const newStock = input.value;
        try {
            const res = await fetch('/admin/product/update-stock', {
                method: 'PATCH',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ productId, newStock })
            });
            const data = await res.json();
            if (data.success) {
                input.classList.add('bg-green-50', 'border-green-400');
                setTimeout(() => input.classList.remove('bg-green-50', 'border-green-400'), 1000);
                refreshDashboardData();
            }
        } catch (e) { console.error("Stock update failed"); }
    }

    // AJAX: Toggle Product Visibility
    async function toggleProductStatus(id) {
        try {
            const res = await fetch(`/admin/product/toggle/${id}`, { method: 'POST' });
            const data = await res.json();
            if (data.success) {
                const row = document.getElementById(`row-${id}`);
                const btn = document.getElementById(`toggle-${id}`);
                const badge = document.getElementById(`badge-${id}`);
                
                if (data.isActive) {
                    row.classList.remove('hidden-item');
                    btn.innerText = 'Hide';
                } else {
                    row.classList.add('hidden-item');
                    btn.innerText = 'Show';
                    badge.innerText = 'HIDDEN';
                    badge.className = "px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-tighter text-white bg-slate-400";
                }
                refreshDashboardData();
            }
        } catch (e) { alert("Toggle Error"); }
    }

    // AJAX: Update Order Status
    async function updateOrderStatus(orderId, status) {
        try {
            const res = await fetch('/admin/order/status', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ orderId, status })
            });
            const data = await res.json();
            if (data.success) refreshDashboardData();
        } catch (e) { console.error("Order status update failed"); }
    }

    // Global Data Sync
    async function refreshDashboardData() {
        try {
            const response = await fetch('/admin/dashboard-data');
            const data = await response.json();
            if (data.success && data.stats) {
                document.getElementById('stat-revenue').textContent = data.stats.totalRevenue.replace('₹', '');
                document.getElementById('stat-active').textContent = data.stats.activeOrders;
                document.getElementById('stat-low').textContent = data.stats.lowStockCount;
                document.getElementById('stat-total').textContent = data.stats.orderCount;
            }
        } catch (err) { console.warn("Sync failed - will retry"); }
    }

    // Auto-refresh stats every 30 seconds
    setInterval(refreshDashboardData, 30000);
</script>

</body>
</html>